---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Intro from '../components/Intro.astro';
import Nosotros from '../components/Nosotros.astro';
import Features from '../components/Features.astro';
import InstalacionesBento from '../components/InstalacionesBento.astro';
import Foother from '../components/Foother.astro';
import Mapa from '../components/Mapa.astro'
---

<Layout title="Clínica Privada | Especialidades Médicas">
	<main>
		<Intro />
		<div class="spacer"></div>
		<Nosotros />
        <div class="spacer"></div>
		<Features />
        <div class="spacer"></div>
		<InstalacionesBento />
		<Mapa />
		<Foother />
	</main>
	
</Layout>

---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
// ... tus otros imports
---

<Layout title="Clínica Privada | Especialidades Médicas">
    <div class="fixed-background"></div>

    <main class="relative z-10">
        <div class="spacer-mini"></div> <Intro />
        <div class="spacer"></div>
        <Nosotros />
        <div class="spacer"></div>
        <Features />
        <div class="spacer"></div>
        <InstalacionesBento />
        <Mapa />
        <div class="spacer"></div>
        <Foother />
    </main>
</Layout>

<style is:global>
    body {
        margin: 0;
        padding: 0;
        /* Quitamos el fondo del body para que no bloquee el modal */
        background-color: #f0f4f8; 
    }

    .fixed-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        /* El z-index negativo es vital para que no tape los botones */
        z-index: -1; 
        
        /* 1. Asegúrate de que el nombre del archivo sea exacto (ej. fondo.JPG vs fondo.jpg) */
        background-image: 
            linear-gradient(rgba(0, 174, 239, 0.45) 0%, rgba(0, 174, 239, 0.25) 100%), 
            url('/fondo.jpg'); 
        
        background-position: center;
        background-size: cover;
        background-repeat: no-repeat;
        /* Esto duplica el brillo para que resalte más */
        filter: brightness(1.1); 
    }

    .spacer {
        height: 450px; 
        background: transparent;
    }

    .spacer-mini {
        height: 80px; /* Altura del Navbar aproximadamente */
    }
</style>