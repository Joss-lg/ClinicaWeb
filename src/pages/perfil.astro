---
import LayoutDoctor from '../layouts/LayoutDoctor.astro';
---

<LayoutDoctor title="Mi Perfil - Clínica Privada">
  <div class="container mx-auto px-6 max-w-4xl">
    
    <div class="flex items-center gap-6 mb-10 animate-fade-in">
      <div class="relative group">
        <div id="avatar-container" class="w-28 h-28 bg-[#0ea5e9] rounded-[2.5rem] flex items-center justify-center text-white text-4xl font-black shadow-xl shadow-blue-100 overflow-hidden border-4 border-white transition-transform group-hover:scale-105">
          <span id="perfil-inicial">D</span>
          <img id="perfil-img" class="hidden w-full h-full object-cover" src="" alt="Foto de perfil">
        </div>
        
        <label for="input-foto" class="absolute -bottom-2 -right-2 bg-white p-2.5 rounded-2xl shadow-lg border border-slate-100 text-[#0ea5e9] hover:bg-[#0ea5e9] hover:text-white transition-all cursor-pointer active:scale-90">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <input type="file" id="input-foto" accept="image/*" class="hidden">
        </label>
      </div>

      <div>
        <h1 id="perfil-nombre-header" class="text-3xl font-black text-[#1a365d] uppercase tracking-tighter leading-none mb-2">Cargando...</h1>
        <p id="perfil-esp-header" class="text-[#0ea5e9] font-bold uppercase text-[10px] tracking-[0.25em] bg-blue-50 px-3 py-1 rounded-full inline-block"></p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="md:col-span-2 space-y-6">
        <div class="bg-white rounded-[2.5rem] p-8 shadow-sm border border-slate-100">
          <h2 class="text-xs font-black text-[#1a365d] uppercase tracking-widest mb-8 flex items-center gap-2">
            <span class="w-2 h-2 bg-[#0ea5e9] rounded-full"></span>
            Información Profesional
          </h2>
          
          <div class="space-y-6">
            <div>
              <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3 block ml-1">Nombre Completo</label>
              <input type="text" id="input-nombre" class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-4 text-sm font-bold text-[#1a365d] focus:bg-white focus:border-blue-100 focus:ring-4 focus:ring-blue-50/50 outline-none transition-all">
            </div>
            
            <div>
              <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3 block ml-1">Especialidad</label>
              <div class="relative">
                <input type="text" id="input-esp" disabled class="w-full bg-slate-100 border-none rounded-2xl px-5 py-4 text-sm font-bold text-slate-400 cursor-not-allowed">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 absolute right-4 top-1/2 -translate-y-1/2 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
              </div>
              <p class="text-[9px] text-slate-400 mt-3 font-medium italic px-1">* Por seguridad, la especialidad solo es editable por el administrador.</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-[2.5rem] p-8 shadow-sm border border-slate-100">
          <h2 class="text-xs font-black text-[#1a365d] uppercase tracking-widest mb-6 flex items-center gap-2">
            <span class="w-2 h-2 bg-[#0ea5e9] rounded-full"></span>
            Acceso
          </h2>
          <button class="w-full flex items-center justify-between p-5 bg-slate-50 rounded-[1.5rem] hover:bg-blue-50 transition-all group">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-[#0ea5e9] shadow-sm group-hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
              </div>
              <span class="text-[11px] font-black text-[#1a365d] uppercase tracking-wider">Actualizar Contraseña</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-300 group-hover:text-[#0ea5e9] transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 5l7 7-7 7" /></svg>
          </button>
        </div>
      </div>

      <div class="space-y-6">
        <div class="bg-[#1a365d] rounded-[2.5rem] p-8 text-white shadow-2xl shadow-blue-900/20 relative overflow-hidden">
          <div class="absolute -top-10 -right-10 w-32 h-32 bg-white/5 rounded-full blur-3xl"></div>
          
          <h3 class="text-[10px] font-black uppercase tracking-[0.2em] mb-6 opacity-50">Estado de Cuenta</h3>
          <div class="flex items-center gap-4 mb-8 bg-white/5 p-4 rounded-2xl border border-white/10">
            <div class="relative flex">
              <span class="absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75 animate-ping"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-green-400"></span>
            </div>
            <span class="text-xs font-black uppercase tracking-[0.1em]">Servidor Activo</span>
          </div>
          
          <button id="btn-guardar" class="w-full bg-[#0ea5e9] py-4 rounded-2xl text-[11px] font-black uppercase tracking-[0.15em] shadow-xl shadow-[#0ea5e9]/30 hover:bg-[#0284c7] hover:-translate-y-1 active:translate-y-0 transition-all">
            Guardar Cambios
          </button>
        </div>

        <button id="btn-logout" class="w-full py-5 rounded-[2rem] border-2 border-red-50 text-red-400 text-[10px] font-black uppercase tracking-[0.2em] hover:bg-red-50 hover:text-red-500 hover:border-red-100 transition-all flex items-center justify-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M17 16l4-4m0 0l-4-4m4 4H7" /></svg>
          Cerrar Sesión
        </button>
      </div>
    </div>
  </div>

  <script is:inline>
    // 1. Elementos y Datos
    const doctorData = JSON.parse(localStorage.getItem('doctor_sesion'));
    const perfilImg = document.getElementById('perfil-img');
    const perfilInicial = document.getElementById('perfil-inicial');
    const inputFoto = document.getElementById('input-foto');

    if (!doctorData) {
      window.location.href = '/login';
    } else {
      // Poblar Textos
      document.getElementById('perfil-nombre-header').innerText = doctorData.nombre;
      document.getElementById('perfil-esp-header').innerText = doctorData.especialidad;
      document.getElementById('input-nombre').value = doctorData.nombre;
      document.getElementById('input-esp').value = doctorData.especialidad;
      
      // Poblar Foto si existe
      if (doctorData.foto) {
        perfilImg.src = doctorData.foto;
        perfilImg.classList.remove('hidden');
        perfilInicial.classList.add('hidden');
      } else {
        perfilInicial.innerText = doctorData.nombre.charAt(0);
      }
    }

    // 2. Lógica para Procesar Nueva Foto
    inputFoto.onchange = (e) => {
      const file = e.target.files[0];
      if (file) {
        // Validar tamaño (máx 2MB sugerido para localStorage)
        if (file.size > 2 * 1024 * 1024) {
          alert("La imagen es muy pesada. Intenta con una menor a 2MB.");
          return;
        }

        const reader = new FileReader();
        reader.onload = (event) => {
          const base64Image = event.target.result;
          
          // Previsualización instantánea
          perfilImg.src = base64Image;
          perfilImg.classList.remove('hidden');
          perfilInicial.classList.add('hidden');

          // Asignar temporalmente al objeto
          doctorData.foto = base64Image;
        };
        reader.readAsDataURL(file);
      }
    };

    // 3. Lógica de Guardar Final
    document.getElementById('btn-guardar').onclick = () => {
      const nuevoNombre = document.getElementById('input-nombre').value;
      
      if(nuevoNombre.trim() === "") return alert("El nombre no puede estar vacío.");

      // Guardamos tanto el nombre como la foto en el objeto final
      const nuevaData = { ...doctorData, nombre: nuevoNombre };
      localStorage.setItem('doctor_sesion', JSON.stringify(nuevaData));
      
      alert("✅ Cambios guardados en tu perfil.");
      location.reload(); // Recarga para actualizar Navbar también
    };

    // 4. Logout
    document.getElementById('btn-logout').onclick = () => {
      localStorage.removeItem('doctor_sesion');
      window.location.href = '/login';
    };
  </script>
</LayoutDoctor>

<style>
  .animate-fade-in {
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>