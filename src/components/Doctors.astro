---
// src/pages/doctores.astro
import Layout from '../layouts/Layout.astro';

const doctores = [
  {
    n: "Dra. Elena Rodríguez",
    e: "Cardiología",
    u: "Tec de Monterrey",
    i: "/public/doc1.webp",
    exp: "Experta en salud cardiovascular y alta prevención crítica.",
    est: "Médico Cirujano (ITESM), Especialidad en Cardiología."
  },
  {
    n: "Dr. Alejandro Méndez",
    e: "Cirugía General",
    u: "UNAM",
    i: "/public/doc2.webp",
    exp: "Líder en intervenciones de mínima invasión y laparoscopia.",
    est: "Médico Cirujano (UNAM), Especialidad en Cirugía General."
  },
  {
    n: "Dra. Sofía Vaca",
    e: "Dermatología",
    u: "UANL",
    i: "/public/doc3.webp",
    exp: "Enfoque en salud cutánea y estética regenerativa.",
    est: "Médico Cirujano (UANL), Especialidad en Dermatología."
  },
  {
    n: "Dr. Javier López",
    e: "Urología",
    u: "UNAM",
    i: "/public/doc4.webp",
    exp: "Pionero en el uso de sistemas robóticos urológicos.",
    est: "Médico Cirujano (UNAM), Especialidad en Urología."
  }
];
---

<Layout title="Nuestro Equipo Médico">
  
  <section class="pt-32 pb-20 bg-white">
    <div class="container mx-auto px-6 max-w-7xl text-center md:text-left">
      <h1 class="text-5xl md:text-7xl font-black text-[#1a365d] tracking-tighter uppercase leading-[0.9] mb-6">
        Nuestro Equipo <br/> <span class="text-[#0ea5e9]">Médico</span>
      </h1>
      <p class="text-slate-500 font-medium max-w-xl text-lg">Especialistas de élite comprometidos con tu salud y bienestar integral.</p>
    </div>
  </section>

  <section class="pb-24 bg-transparent relative">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {doctores.map((doc) => (
          <div class="group bg-white rounded-[2.5rem] shadow-sm hover:shadow-2xl transition-all duration-500 border border-slate-100 overflow-hidden flex flex-col">
            <div class="aspect-[4/5] overflow-hidden bg-slate-100">
              <img src={doc.i} alt={doc.n} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" loading="lazy" />
            </div>
            <div class="p-8 flex-grow flex flex-col justify-between">
              <div class="text-center">
                <span class="text-[#0ea5e9] text-[9px] font-black uppercase tracking-widest mb-2 block">{doc.e}</span>
                <h4 class="text-xl font-black text-[#1a365d] mb-1 leading-tight">{doc.n}</h4>
                <p class="text-slate-400 text-[10px] font-bold uppercase mb-6">{doc.u}</p>
              </div>
              
              <button 
                class="trigger-perfil w-full bg-[#1a365d] text-white py-4 rounded-2xl text-[10px] font-bold uppercase tracking-widest hover:bg-[#0ea5e9] transition-all shadow-lg shadow-blue-900/10"
                data-nombre={doc.n} 
                data-imagen={doc.i} 
                data-esp={doc.e} 
                data-tray={doc.exp} 
                data-est={doc.est}
              >
                Ver Perfil Completo
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div id="pestaña-doctor" class="fixed inset-0 bg-slate-950/90 backdrop-blur-md z-[100] hidden items-center justify-center p-4">
    <div class="bg-white rounded-[2.5rem] max-w-4xl w-full overflow-hidden shadow-2xl flex flex-col md:flex-row relative">
      <button id="cerrar-pestaña" class="absolute top-6 right-6 z-10 bg-slate-100 p-3 rounded-full text-slate-950 hover:bg-red-600 hover:text-white transition-all cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
      <div class="md:w-5/12 h-64 md:h-auto"><img id="p-foto" src="" class="w-full h-full object-cover" /></div>
      <div class="md:w-7/12 p-8 md:p-12 flex flex-col justify-center">
        <h5 id="p-tit" class="text-4xl font-black text-[#1a365d] mb-1 uppercase tracking-tighter"></h5>
        <p id="p-sub" class="text-[#0ea5e9] font-bold text-xs uppercase mb-8 tracking-widest"></p>
        <div class="space-y-6 text-sm">
          <div><p class="text-slate-400 font-black uppercase text-[9px] mb-2">Trayectoria:</p><p id="p-exp-text" class="italic text-slate-600 border-l-4 border-[#0ea5e9] pl-4"></p></div>
          <div><p class="text-slate-400 font-black uppercase text-[9px] mb-2">Formación:</p><p id="p-est-text" class="font-bold text-[#1a365d]"></p></div>
        </div>
        <button id="btnCitaDesdePerfil" class="mt-8 bg-[#0ea5e9] text-white py-4 rounded-xl font-black text-[10px] uppercase tracking-widest">Agendar con este Especialista</button>
      </div>
    </div>
  </div>

  <div id="modalCita" class="fixed inset-0 z-[110] flex items-center justify-center opacity-0 invisible transition-all duration-300">
    <div id="closeModalBg" class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm"></div>
    <div class="relative bg-white w-full max-w-lg mx-4 rounded-[2.5rem] shadow-2xl transform scale-95 transition-transform duration-300" id="modalContent">
        <button id="closeFormBtn" class="absolute top-6 right-6 text-slate-400 hover:text-slate-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
        <div class="p-10">
            <h2 class="text-3xl font-black text-[#1a365d] mb-2">Agendar Cita</h2>
            <p class="text-slate-500 mb-8 font-medium text-sm">Completa tus datos y te contactaremos en breve.</p>
            <form class="space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <input type="text" placeholder="Nombre" class="w-full px-5 py-3 bg-slate-50 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm font-bold" />
                    <input type="tel" placeholder="Teléfono" class="w-full px-5 py-3 bg-slate-50 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm font-bold" />
                </div>
                <select id="selectEspecialidad" class="w-full px-5 py-3 bg-slate-50 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm font-bold text-slate-500">
                    <option disabled selected>Especialidad...</option>
                    <option>Urología</option>
                    <option>Cardiología</option>
                    <option>Cirugía General</option>
                    <option>Dermatología</option>
                </select>
                <textarea rows="3" placeholder="Motivo de consulta" class="w-full px-5 py-3 bg-slate-50 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm font-bold resize-none"></textarea>
                <button type="button" class="w-full py-4 bg-[#1a365d] text-white rounded-xl font-bold uppercase tracking-widest hover:bg-[#0ea5e9] transition-all">Enviar Solicitud</button>
            </form>
        </div>
    </div>
  </div>

</Layout>

<style>
    .modal-active { opacity: 1 !important; visibility: visible !important; }
    .modal-active #modalContent { transform: scale(1) !important; }
</style>

<script is:inline>
  const modalPerfil = document.getElementById('pestaña-doctor');
  const modalForm = document.getElementById('modalCita');
  
  // Abrir Perfil
  document.querySelectorAll('.trigger-perfil').forEach(btn => {
    btn.onclick = () => {
      const d = btn.dataset;
      document.getElementById('p-tit').innerText = d.nombre;
      document.getElementById('p-sub').innerText = d.esp;
      document.getElementById('p-exp-text').innerText = d.tray;
      document.getElementById('p-est-text').innerText = d.est;
      document.getElementById('p-foto').src = d.imagen;
      modalPerfil.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    };
  });

  // Funciones Formulario
  const toggleForm = () => {
    modalForm.classList.toggle('modal-active');
    // Si abrimos el formulario desde el perfil, cerramos el perfil primero
    if (modalPerfil.style.display === 'flex') {
        modalPerfil.style.display = 'none';
    } else {
        document.body.style.overflow = document.body.style.overflow === 'hidden' ? 'auto' : 'hidden';
    }
  };

  const closePerfil = () => {
    modalPerfil.style.display = 'none';
    document.body.style.overflow = 'auto';
  };

  // Event Listeners
  document.getElementById('cerrar-pestaña').onclick = closePerfil;
  document.getElementById('closeFormBtn').onclick = toggleForm;
  document.getElementById('closeModalBg').onclick = toggleForm;
  document.getElementById('openFormCTA').onclick = toggleForm;
  document.getElementById('btnCitaDesdePerfil').onclick = toggleForm;

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closePerfil();
      modalForm.classList.remove('modal-active');
    }
  });
</script>