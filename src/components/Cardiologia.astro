---
// src/components/Cardiologia.astro
---
<section class="py-24 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="mb-16">
      <h2 class="text-xs font-bold text-accent tracking-[0.3em] uppercase mb-4">Unidad del Corazón</h2>
      <h3 class="text-4xl md:text-5xl font-bold text-primary max-w-2xl leading-[1.1]">
        Cuidamos el motor de su vida con <span class="text-secondary font-light italic text-3xl md:text-4xl">precisión clínica.</span>
      </h3>
    </div>

    <div class="grid lg:grid-cols-12 gap-8">
      
      <div class="lg:col-span-7 group relative">
        <div class="overflow-hidden rounded-2xl aspect-video bg-slate-100 mb-8 shadow-inner">
          <img 
            src="https://images.unsplash.com/photo-1628177142898-93e36e4e3a50?auto=format&fit=crop&q=80&w=1400" 
            alt="Consulta de Cardiología" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          />
        </div>
        <div class="bg-primary p-10 rounded-2xl text-white shadow-2xl relative z-10 -mt-20 ml-6 mr-6 md:ml-12 md:mr-12">
            <h4 class="text-xl font-bold mb-4 italic">Diagnóstico No Invasivo</h4>
            <p class="text-blue-100 leading-relaxed font-light">
                Nuestro centro cuenta con tecnología de última generación para la detección temprana de patologías cardiovasculares sin procedimientos traumáticos.
            </p>
        </div>
      </div>

      <div class="lg:col-span-5 grid grid-cols-1 gap-6">
        {[
          { 
            titulo: 'Ecocardiografía Doppler', 
            desc: 'Visualización en tiempo real del flujo sanguíneo y estructuras cardíacas.' 
          },
          { 
            titulo: 'Pruebas de Esfuerzo', 
            desc: 'Evaluación de la respuesta del corazón ante la actividad física controlada.' 
          },
          { 
            titulo: 'Holter de Ritmo (24/48h)', 
            desc: 'Monitoreo ambulatorio para detección de arritmias y síncopes.' 
          }
        ].map((item) => (
          <div class="p-8 border border-slate-100 rounded-2xl hover:shadow-xl hover:shadow-slate-100 transition-all border-l-4 border-l-accent">
            <h5 class="font-bold text-primary mb-2 text-lg uppercase tracking-tight">{item.titulo}</h5>
            <p class="text-secondary text-sm leading-relaxed font-medium">{item.desc}</p>
          </div>
        ))}

        <div class="mt-4 p-8 bg-blue-50 rounded-2xl border border-blue-100">
            <p class="text-primary font-bold mb-3">¿Tiene antecedentes familiares?</p>
            <p class="text-sm text-slate-600 mb-6 italic">La prevención es la clave para una vida longeva.</p>
            <button class="w-full py-4 border-2 border-primary text-primary font-bold rounded-lg hover:bg-primary hover:text-white transition-all uppercase text-xs tracking-widest">
                Check-up Cardiovascular
            </button>
        </div>
      </div>

    </div>
  </div>
</section>