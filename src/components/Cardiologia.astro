---
// src/components/Cardiologia.astro
---
<section id="cardiology-section" class="py-16 md:py-24  bg-transparent overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="mb-12 md:mb-16 reveal-card opacity-0 translate-y-4 transition-all duration-1000 text-center lg:text-left">
      <h2 class="text-xs font-bold text-[#0ea5e9] tracking-[0.3em] uppercase mb-4">Unidad del Corazón</h2>
      <h3 class="text-3xl md:text-5xl font-bold text-[#1a365d] max-w-2xl mx-auto lg:mx-0 leading-[1.1]">
        Cuidamos el motor de su vida con <span class="text-slate-500 font-light italic text-2xl md:text-4xl block md:inline">precisión clínica.</span>
      </h3>
    </div>

    <div class="grid lg:grid-cols-12 gap-12 items-start">
      
      <div class="lg:col-span-7 flex flex-col gap-8">
        <div class="group relative reveal-card opacity-0 -translate-x-5 transition-all duration-1000">
          <div class="overflow-hidden rounded-3xl aspect-video bg-slate-100 mb-8 shadow-sm">
            <img 
              src="cardiologia.webp" 
              alt="Consulta Cardiología" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-[3000ms] ease-out"
            />
          </div>
          <div class="bg-[#1a365d] p-8 md:p-10 rounded-2xl text-white shadow-2xl relative z-10 -mt-20 md:-mt-24 mx-4 md:mx-12 border border-white/10 backdrop-blur-sm text-center md:text-left">
              <h4 class="text-xl font-bold mb-3 italic">Diagnóstico No Invasivo</h4>
              <p class="text-blue-100 font-light leading-relaxed text-sm md:text-base">
                Tecnología de última generación para la detección temprana de patologías sin procedimientos traumáticos.
              </p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-4">
          {[
            { n: '15k+', t: 'Pacientes' },
            { n: '99%', t: 'Precisión' },
            { n: '24/7', t: 'Atención' }
          ].map((stat, index) => (
            <div 
              class="reveal-card opacity-0 translate-y-6 p-5 md:p-6 rounded-2xl bg-slate-50 border border-slate-100 text-center group hover:bg-[#1a365d] transition-all duration-700"
              style={`transition-delay: ${400 + (index * 100)}ms;`}
            >
              <span class="block text-3xl font-bold text-[#1a365d] group-hover:text-white mb-1">{stat.n}</span>
              <span class="text-[10px] uppercase tracking-widest text-slate-500 group-hover:text-blue-200">{stat.t}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="lg:col-span-5 flex flex-col gap-6">
        {
          [
            { titulo: 'Ecocardiografía Doppler', desc: 'Visualización en tiempo real del flujo sanguíneo cardíaco.' },
            { titulo: 'Pruebas de Esfuerzo', desc: 'Evaluación de la respuesta del corazón ante la actividad física.' },
            { titulo: 'Holter de Ritmo (24/48h)', desc: 'Monitoreo ambulatorio para detección de arritmias y síncopes.' }
          ].map((item, index) => (
            <div 
              class="reveal-card opacity-0 translate-x-8 
                     group relative p-6 md:p-8 border border-slate-100 rounded-2xl bg-white
                     hover:shadow-2xl hover:shadow-blue-900/5 hover:-translate-y-1 transition-all duration-700 ease-out border-l-4 border-l-[#0ea5e9] overflow-hidden text-center md:text-left"
              style={`transition-delay: ${index * 150}ms;`} 
            >
              <h5 class="font-bold text-[#1a365d] group-hover:text-black mb-2 text-base md:text-lg uppercase tracking-tight relative z-10 transition-colors">
                  {item.titulo}
              </h5>
              <p class="text-slate-500 group-hover:text-slate-900 text-sm leading-relaxed relative z-10 transition-colors">
                  {item.desc}
              </p>
            </div>
          ))
        }

        <div 
          class="reveal-card opacity-0 translate-y-10 mt-2 p-8 bg-gradient-to-br from-blue-50 to-white rounded-3xl border border-blue-100 relative overflow-hidden group transition-all duration-1000 text-center md:text-left"
          style="transition-delay: 500ms;"
        >
            <p class="text-[#1a365d] font-bold text-lg mb-6">¿Tiene antecedentes familiares?</p>
            <a 
              href="cardiologia.webp" 
              target="_blank" 
              class="w-full py-4 bg-[#25D366] text-white font-bold rounded-xl hover:bg-[#20ba5a] transition-all uppercase text-xs tracking-widest flex items-center justify-center gap-3 shadow-lg"
            >
              Consultar Especialista
            </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initCardioReveal() {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Eliminamos todas las clases de "oculto"
          entry.target.classList.remove('opacity-0', 'translate-y-4', 'translate-y-6', 'translate-y-10', 'translate-x-8', '-translate-x-5');
          // Añadimos las de "visible"
          entry.target.classList.add('opacity-100', 'translate-y-0', 'translate-x-0');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Buscamos todos los elementos con la clase reveal-card
    const targets = document.querySelectorAll('.reveal-card');
    targets.forEach((el) => observer.observe(el));
  }

  // Se ejecuta al cargar la página
  initCardioReveal();
  
  // Se ejecuta cuando Astro cambia de página (View Transitions)
  document.addEventListener('astro:after-swap', initCardioReveal);
</script>

<style>
  .reveal-card {
    will-change: transform, opacity;
  }
</style>