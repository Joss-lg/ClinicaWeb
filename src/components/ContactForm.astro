---
// src/components/ContactForm.astro
---
<div class="bg-white p-8 md:p-12 rounded-[3rem] shadow-xl border border-slate-100 relative overflow-hidden">
    <div class="absolute -top-10 -right-10 w-32 h-32 bg-blue-50 rounded-full opacity-50"></div>

    <form class="relative z-10 space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
            <div class="space-y-2">
                <label class="text-[10px] font-black uppercase text-slate-400 ml-2">Nombre Completo</label>
                <input type="text" placeholder="Ej. Juan Pérez" class="w-full px-6 py-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none font-bold text-sm transition-all" />
            </div>
            <div class="space-y-2">
                <label class="text-[10px] font-black uppercase text-slate-400 ml-2">WhatsApp / Tel</label>
                <input type="tel" placeholder="55 0000 0000" class="w-full px-6 py-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none font-bold text-sm transition-all" />
            </div>
        </div>

        <div class="space-y-2">
            <label class="text-[10px] font-black uppercase text-slate-400 ml-2">Asunto</label>
            <select class="w-full px-6 py-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none font-bold text-sm text-slate-500 transition-all appearance-none">
                <option>Información General</option>
                <option>Citas Médicas</option>
                <option>Facturación</option>
                <option>Quejas y Sugerencias</option>
            </select>
        </div>

        <div class="space-y-2">
            <label class="text-[10px] font-black uppercase text-slate-400 ml-2">Mensaje</label>
            <textarea rows="4" placeholder="¿En qué podemos ayudarte?" class="w-full px-6 py-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none font-bold text-sm resize-none transition-all"></textarea>
        </div>

        <button type="submit" class="w-full py-5 bg-[#1a365d] text-white rounded-2xl font-black text-xs uppercase tracking-[0.2em] hover:bg-blue-600 hover:-translate-y-1 shadow-lg shadow-blue-900/20 transition-all">
            Enviar Mensaje Directo
        </button>
    </form>
</div>