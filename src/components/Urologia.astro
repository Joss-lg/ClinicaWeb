---
// src/components/Urologia.astro
---

<section id="urology-section" class="py-24  bg-transparent overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-20 items-center">
      
      <div class="relative group order-2 lg:order-1">
        <div class="absolute -top-10 -left-10 w-72 h-72 bg-blue-100 rounded-full blur-3xl opacity-60 group-hover:bg-blue-200 transition-colors duration-700"></div>
        
        <div class="relative z-10">
          <div class="overflow-hidden rounded-[2.5rem] shadow-2xl border-[12px] border-slate-50">
            <img 
              src="urologia.webp" 
              alt="Tecnología Médica Avanzada" 
              class="urologia.webp"
            />
          </div>
          
          <div class="absolute -top-4 right-8 bg-blue-600 text-white px-6 py-3 rounded-2xl shadow-xl font-bold text-sm tracking-wide animate-bounce-slow">
            Equipamiento Robotizado
          </div>

          <div class="absolute -bottom-6 -right-6 bg-white/80 backdrop-blur-md p-6 rounded-3xl shadow-xl border border-white max-w-[220px]">
            <div class="flex flex-col gap-2">
              <span class="text-blue-600 font-black text-2xl leading-none">98%</span>
              <span class="text-slate-600 text-xs font-semibold leading-tight">Efectividad en Cirugía Mínimamente Invasiva</span>
            </div>
          </div>
        </div>
      </div>

      <div class="order-1 lg:order-2">
        <div class="inline-block px-4 py-1.5 rounded-full bg-blue-50 text-blue-600 text-xs font-black uppercase tracking-widest mb-6">
          Especialidad Médica
        </div>
        
        <h2 class="text-5xl font-black text-blue-950 mb-8 leading-[1.1] tracking-tight">
          Unidad de <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-blue-400 italic font-light">
            Urología Avanzada
          </span>
        </h2>

        <p class="text-lg text-slate-600 mb-10 leading-relaxed italic">
          "Innovación al servicio de tu bienestar: Diagnósticos precisos y tratamientos de recuperación rápida."
        </p>

        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
          {[
            'Cirugía Robótica',
            'Láser de Próstata',
            'Litiasis Renal',
            'Onco-Urología'
          ].map((servicio) => (
            <li class="flex items-center gap-3 text-slate-700 font-bold group">
              <div class="w-6 h-6 bg-blue-600 rounded-full flex items-center justify-center group-hover:bg-blue-400 transition-colors">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
              </div>
              {servicio}
            </li>
          ))}
        </ul>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes bounceSlow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .animate-bounce-slow {
    animation: bounceSlow 3s infinite ease-in-out;
  }
</style>