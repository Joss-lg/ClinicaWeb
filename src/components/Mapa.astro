---
// src/components/Mapa.astro
const { url = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d240924.89814069596!2d-99.47666521328122!3d19.34959190000001!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85d1ff9787508767%3A0xf8525c88b61714e3!2sPunto%20Cl%C3%ADnico%20Especialistas%20-%20Cuauht%C3%A9moc!5e0!3m2!1ses!2smx!4v1775597470549!5m2!1ses!2smx" } = Astro.props;
---

<section id="ubicacion" class="py-16 md:py-24 bg-slate-950 border-t border-white/5">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      
      <div class="lg:col-span-5 order-2 lg:order-1">
        <h5 class="text-blue-500 font-black text-[10px] uppercase tracking-[0.3em] mb-4 text-center lg:text-left">Ubicación Estratégica</h5>
        <h2 class="text-3xl md:text-5xl font-serif italic text-white mb-6 text-center lg:text-left">
          Tu salud, en el <span class="text-blue-600 not-italic font-sans font-black">corazón</span> de la ciudad.
        </h2>
        
        <div class="space-y-6 max-w-md mx-auto lg:mx-0">
          <div class="flex items-center gap-4">
             <div class="w-10 h-10 rounded-full bg-blue-600/10 flex items-center justify-center text-blue-500 shrink-0">
              <ion-icon name="location-outline" class="text-xl"></ion-icon>
            </div>
            <p class="text-slate-400 text-sm">Av. Principal Médica #450, Piso 4. CDMX.</p>
          </div>
        </div>

        <div class="mt-10 text-center lg:text-left">
          <a href="https://www.google.com/maps/search/?api=1&query=Av.+Principal+M%C3%A9dica+450%2C+Piso+4%2C+Ciudad+de+M%C3%A9xico%2C+CP+01000" target="_blank" class="inline-flex items-center gap-2 text-blue-500 font-bold text-xs uppercase tracking-widest hover:text-white transition-colors group">
            Obtener indicaciones 
            <ion-icon name="arrow-forward-outline" class="group-hover:translate-x-1 transition-transform"></ion-icon>
          </a>
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2">
        <div class="relative overflow-hidden rounded-[2rem] border border-white/10 shadow-2xl bg-slate-900">
          
          <iframe 
            src={url}
            class="w-full h-[350px] md:h-[480px] opacity-100 transition-opacity duration-500 ease-in-out"
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy">
          </iframe>

          <div class="absolute inset-0 pointer-events-none border border-white/5 rounded-[2rem]"></div>
        </div>
      </div>

    </div>
  </div>
</section>