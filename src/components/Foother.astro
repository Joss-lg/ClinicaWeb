---
// src/components/Footer.astro
const año = new Date().getFullYear();
const whatsappLink = "https://wa.me/1234567890?text=Hola,%20deseo%20consultar%20con%20un%20especialista.";
---

<footer class="bg-slate-950 text-white pt-20 pb-10 border-t border-blue-900/20">
  <div id="contact-section" class="container mx-auto px-6 max-w-6xl">
    
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-16">
      
      <div class="md:col-span-5">
        <h4 class="text-3xl font-serif italic mb-4 text-white">Clínica <span class="text-blue-600 not-italic font-sans font-black tracking-tighter">Especializada</span></h4>
        <p class="text-slate-400 text-base font-light leading-relaxed max-w-sm">
          Innovación médica y calidez humana al servicio de tu bienestar. Comprometidos con la excelencia en cada diagnóstico y tratamiento.
        </p>
      </div>

      <div class="md:col-span-3">
        <h5 class="text-white font-black text-[11px] uppercase tracking-[0.2em] mb-6 text-blue-500">Navegación</h5>
        <ul class="space-y-3 text-base text-slate-300">
          <li><a href="#inicio" class="hover:text-blue-500 transition-colors">Centro Médico</a></li>
          <li><a href="#urology-section" class="hover:text-blue-500 transition-colors">Especialidades</a></li>
          <li><a href="#doctors-section" class="hover:text-blue-500 transition-colors">Nuestros Doctores</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <h5 class="text-white font-black text-[11px] uppercase tracking-[0.2em] mb-6 text-blue-500">Contacto</h5>
        <div class="space-y-6">
            <div>
                <p class="text-[10px] font-bold text-slate-500 uppercase mb-1">Línea Urgencias</p>
                <p class="text-xl font-serif italic text-white hover:text-blue-400 transition-colors">+52 (55) 8888 9999</p>
            </div>
            <div>
                <p class="text-[10px] font-bold text-slate-500 uppercase mb-1">Ubicación</p>
                <p class="text-sm text-slate-300 font-light leading-relaxed">Av. Principal Médica #450, Piso 4.<br/>Ciudad de México, CP 01000.</p>
            </div>
        </div>
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center gap-8 py-10 border-y border-slate-900/50 mb-10">
        
        <div class="flex flex-col md:flex-row gap-6 md:gap-12">
            <div>
                <p class="text-[10px] font-black text-blue-500 uppercase tracking-[0.2em] mb-2">Lunes a Viernes</p>
                <p class="text-sm text-white font-bold">08:00 AM — 20:00 PM</p>
            </div>
            <div>
                <p class="text-[10px] font-black text-blue-500 uppercase tracking-[0.2em] mb-2">Fines de Semana</p>
                <p class="text-sm text-white font-bold">09:00 AM — 14:00 PM</p>
            </div>
        </div>

        <div class="flex items-center gap-6">
            <p class="hidden lg:block text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Síguenos:</p>
            <div class="flex gap-4">
                <a href="#" target="_blank" class="w-11 h-11 rounded-full border border-slate-800 flex items-center justify-center text-slate-400 hover:bg-blue-600 hover:text-white hover:border-blue-600 transition-all duration-300">
                  <ion-icon name="logo-facebook" class="text-xl"></ion-icon>
                </a>
                <a href="#" target="_blank" class="w-11 h-11 rounded-full border border-slate-800 flex items-center justify-center text-slate-400 hover:bg-gradient-to-tr hover:from-[#f9ce34] hover:via-[#ee2a7b] hover:to-[#6228d7] hover:text-white hover:border-transparent transition-all duration-300">
                  <ion-icon name="logo-instagram" class="text-xl"></ion-icon>
                </a>
                <a href={whatsappLink} target="_blank" class="w-11 h-11 rounded-full border border-slate-800 flex items-center justify-center text-slate-400 hover:bg-[#25D366] hover:text-white hover:border-[#25D366] transition-all duration-300">
                  <ion-icon name="logo-whatsapp" class="text-xl"></ion-icon>
                </a>
            </div>
        </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-[10px] font-medium uppercase tracking-widest text-slate-600">
        © {año} Clínica Especializada <span class="mx-2">|</span> Todos los derechos reservados
      </p>
      
      <div class="flex gap-6 text-[10px] font-bold uppercase tracking-widest text-slate-500">
        <a href="#" class="hover:text-blue-600 transition-colors">Privacidad</a>
        <a href="#" class="hover:text-blue-600 transition-colors">Términos</a>
      </div>
    </div>

  </div>
</footer>