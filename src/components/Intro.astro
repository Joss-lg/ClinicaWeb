---
// IntroMedica.astro - Versión Optimizada
---

<section id="inicio" class="relative bg-white py-20 md:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:20px_20px] opacity-30"></div>
  
  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      
      <div class="space-y-10 animate-fade-in">
        
        <div class="inline-flex items-center space-x-3 px-4 py-2 rounded-full bg-blue-50 border border-blue-100 text-blue-700 shadow-sm">
          <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-blue-600"></span>
          </span>
          <span class="text-xs font-bold uppercase tracking-wider">Atención de Urgencias 24/7</span>
        </div>

        <h1 class="text-5xl md:text-7xl font-black text-slate-900 leading-[1.1] tracking-tight">
          Tu salud merece <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500">atención experta.</span>
        </h1>

        <p class="text-lg md:text-xl text-slate-600 leading-relaxed max-w-lg">
          En nuestra clínica combinamos calidez humana con tecnología de vanguardia para ofrecerte el diagnóstico más preciso y oportuno.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <button id="intro-btnOpen" class="px-8 py-4 bg-blue-600 text-white font-bold rounded-2xl shadow-lg shadow-blue-200 hover:bg-blue-700 hover:-translate-y-1 transition-all text-center">
            Agendar Cita Ahora
          </button>
          
          <a href="tel:+123456789" class="px-8 py-4 bg-white text-slate-700 font-bold rounded-2xl border border-slate-200 hover:bg-slate-50 transition-all flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Llamar a Clínica
          </a>
        </div>

        <div class="grid grid-cols-2 gap-8 pt-10 border-t border-slate-100">
          <div>
            <p class="text-3xl font-black text-slate-900">+15,000</p>
            <p class="text-sm font-medium text-slate-500 uppercase tracking-wide">Pacientes Satisfechos</p>
          </div>
          <div>
            <p class="text-3xl font-black text-slate-900">25+</p>
            <p class="text-sm font-medium text-slate-500 uppercase tracking-wide">Especialistas</p>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="absolute -top-20 -right-20 w-80 h-80 bg-blue-100 rounded-full blur-[100px] opacity-60"></div>
        <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-cyan-100 rounded-full blur-[100px] opacity-60"></div>
        
        <div class="relative z-10">
          <img 
            src="recepcion.webp" 
            alt="Instalaciones Médicas Chulavista" 
            class="rounded-[3rem] shadow-[0_32px_64px_-12px_rgba(0,0,0,0.15)] border-[12px] border-white object-cover aspect-[4/5] w-full transform hover:scale-[1.02] transition-transform duration-500"
          />
          
          <div class="absolute -bottom-8 -left-8 bg-white p-5 rounded-3xl shadow-2xl flex items-center gap-4 border border-slate-50 animate-bounce-slow">
            <div class="w-14 h-14 bg-green-50 rounded-2xl flex items-center justify-center text-green-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
            </div>
            <div>
              <p class="text-xs text-slate-400 font-bold uppercase tracking-tighter">Certificación Oficial</p>
              <p class="text-lg font-black text-slate-900 italic">Excelencia Médica</p>
            </div>
          </div>

          <div class="absolute top-10 -right-6 bg-white/90 backdrop-blur-md p-4 rounded-2xl shadow-xl border border-white/50 hidden md:flex items-center gap-3">
             <div class="flex -space-x-2">
                <div class="w-8 h-8 rounded-full bg-blue-400 border-2 border-white"></div>
                <div class="w-8 h-8 rounded-full bg-slate-300 border-2 border-white"></div>
                <div class="w-8 h-8 rounded-full bg-blue-200 border-2 border-white"></div>
             </div>
             <div>
                <p class="text-xs font-bold text-slate-900">4.9/5 Rating</p>
                <p class="text-[10px] text-slate-500 italic">Opiniones reales</p>
             </div>
          </div>
        </div>
      </div>

    </div>
  </div>
  <div id="intro-modalCita" class="fixed inset-0 z-[110] flex items-center justify-center opacity-0 invisible transition-all duration-300 p-4">
    <div id="intro-closeModalBg" class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm"></div>
    <div class="relative bg-white w-full max-w-lg rounded-[2.5rem] shadow-2xl transform scale-95 transition-transform duration-300" id="intro-modalContent">
        <button id="intro-closeModalBtn" class="absolute top-6 right-6 text-slate-400 hover:text-slate-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
       <div class="p-8 md:p-10">
    <div id="intro-formContainer">
        <h2 class="text-3xl font-black text-[#1a365d] mb-2">Agendar Cita</h2>
        <p class="text-slate-500 mb-8 font-medium">Completa tus datos:</p>
        
        <form id="intro-appointmentForm" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <input name="nombre" type="text" required placeholder="Nombre" class="w-full px-5 py-3 bg-slate-50 border-none rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm font-bold" />
                <input name="telefono" type="tel" required placeholder="Teléfono" class="w-full px-5 py-3 bg-slate-50 border-none rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm font-bold" />
            </div>
            <select name="especialidad" required class="w-full px-5 py-3 bg-slate-50 border-none rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm font-bold text-slate-500">
                <option value="" disabled selected>Especialidad...</option>
                <option>Urología</option>
                <option>Cardiología</option>
                <option>Cirugías</option>
                <option>Dermatología</option>
            </select>
            <textarea name="motivo" rows="3" placeholder="Motivo de consulta" class="w-full px-5 py-3 bg-slate-50 border-none rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm font-bold resize-none"></textarea>
            
            <button type="submit" id="intro-submitBtn" class="w-full py-4 bg-[#1a365d] text-white rounded-xl font-bold uppercase tracking-widest hover:bg-[#0ea5e9] transition-all shadow-lg shadow-blue-900/10">
                Enviar Solicitud
            </button>
        </form>
    </div>

    <div id="intro-errorStatus" class="hidden mt-4 p-4 bg-red-50 text-red-600 rounded-xl text-sm font-bold text-center border border-red-100"></div>
</div>


<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeInUp 1s cubic-bezier(0.21, 1.02, 0.73, 1) forwards;
  }
  @keyframes bounceSlow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }
  .animate-bounce-slow {
    animation: bounceSlow 5s infinite ease-in-out;
  }

  

  /* --- LO QUE DEBES AGREGAR AHORA PARA EL FORMULARIO --- */
  .intro-active { 
    opacity: 1 !important; 
    visibility: visible !important; 
  }
  .intro-active #intro-modalContent { 
    transform: scale(1) !important; 
  }

</style>

<script>
  const initIntroMedicalLogic = () => {
    const modal = document.getElementById('intro-modalCita');
    const container = document.getElementById('intro-formContainer');
    const btnOpen = document.getElementById('intro-btnOpen');
    const btnClose = document.getElementById('intro-closeModalBtn');
    const bgClose = document.getElementById('intro-closeModalBg');
    const form = document.getElementById('intro-appointmentForm') as HTMLFormElement;
    const errorMsg = document.getElementById('intro-errorStatus');
    const submitBtn = document.getElementById('intro-submitBtn') as HTMLButtonElement;

    if (!modal || !btnOpen) return;

    const toggle = () => {
      modal.classList.toggle('intro-active');
      document.body.style.overflow = modal.classList.contains('intro-active') ? 'hidden' : 'auto';
    };

    btnOpen.onclick = toggle;
    if (btnClose) btnClose.onclick = toggle;
    if (bgClose) bgClose.onclick = toggle;

    if (form && submitBtn && container) {
      form.onsubmit = async (e) => {
        e.preventDefault();
        
        submitBtn.disabled = true;
        const originalText = submitBtn.innerText;
        submitBtn.innerText = "PROCESANDO...";
        if (errorMsg) errorMsg.classList.add('hidden');

        try {
          const response = await fetch('http://localhost/save_appointment.php', {
            method: 'POST',
            body: new FormData(form)
          });

          const result = await response.json();

          if (result.success) {
            // DISEÑO DE CONFIRMACIÓN
            container.innerHTML = `
              <div class="text-center py-10 animate-fade-in">
                <div class="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-6 shadow-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <h3 class="text-2xl font-black text-slate-900 mb-2 uppercase tracking-tight">¡Solicitud Enviada!</h3>
                <p class="text-slate-500 font-medium mb-8 leading-relaxed">
                  Hemos recibido tus datos correctamente. Un especialista se pondrá en contacto contigo a la brevedad.
                </p>
                <button onclick="location.reload()" class="px-8 py-3 bg-slate-100 text-slate-600 font-bold rounded-xl hover:bg-slate-200 transition-colors text-sm uppercase tracking-widest">
                  Cerrar
                </button>
              </div>
            `;
          } else {
            throw new Error(result.error || "Error en el servidor");
          }
        } catch (error: any) {
          if (errorMsg) {
            errorMsg.textContent = "Lo sentimos: " + error.message;
            errorMsg.classList.remove('hidden');
          }
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerText = originalText;
        }
      };
    }
  };

  initIntroMedicalLogic();
  document.addEventListener('astro:page-load', initIntroMedicalLogic);
</script>


