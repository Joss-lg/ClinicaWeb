---
// src/components/Hero.astro
---
<section id="inicio" class="pt-32 pb-20 lg:pt-48 lg:pb-32 bg-gradient-to-b from-slate-50 to-white">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
        <div>
            <span class="inline-block px-4 py-1.5 mb-6 text-xs font-semibold tracking-widest text-[#0ea5e9] bg-blue-50 rounded-full uppercase">
                Excelencia Médica
            </span>
            <h1 class="text-5xl lg:text-7xl font-bold text-[#1a365d] leading-tight mb-8">
                Su salud merece el trato de un <span class="text-slate-500 font-light italic">experto.</span>
            </h1>
            <div class="flex flex-wrap gap-4">
                <button class="px-8 py-4 bg-[#1a365d] text-white font-semibold rounded-lg shadow-xl shadow-blue-900/20 hover:scale-105 transition-transform">
                    Agendar Consulta
                </button>
            </div>
        </div>
        <div class="relative aspect-[4/5] bg-slate-200 rounded-2xl overflow-hidden shadow-2xl">
            <div class="w-full h-full bg-[url('https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&q=80&w=1000')] bg-cover bg-center"></div>
        </div>
    </div>
</section>
