---
// src/components/AppointmentForm.astro
---

<div id="formContainer">
  <h2 class="text-3xl font-black text-[#1a365d] mb-2">Agendar Cita</h2>
  <p class="text-slate-500 mb-8 font-medium">Completa tus datos:</p>
  
  <div id="formMessage" class="hidden"></div>

  <form id="appointmentForm" class="space-y-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <input name="nombre" type="text" placeholder="Nombre" required class="w-full px-5 py-3 bg-slate-50 border-none rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm font-bold" />
      <input name="telefono" type="tel" placeholder="Teléfono" required class="w-full px-5 py-3 bg-slate-50 border-none rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm font-bold" />
    </div>
    
    <select name="especialidad" class="w-full px-5 py-3 bg-slate-50 border-none rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm font-bold text-slate-500">
      <option value="">Especialidad...</option>
      <option>Urología</option>
      <option>Cardiología</option>
      <option>Cirugías</option>
      <option>Dermatología</option>
    </select>
    
    <textarea name="mensaje" rows="3" placeholder="Motivo de consulta" class="w-full px-5 py-3 bg-slate-50 border-none rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm font-bold resize-none"></textarea>
    
    <button type="submit" class="w-full py-4 bg-[#1a365d] text-white rounded-xl font-bold uppercase tracking-widest hover:bg-[#0ea5e9] transition-all active:scale-[0.98]">
      Enviar Solicitud
    </button>
  </form>
</div>

<style>
  .animate-success-card { animation: springIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) both; }
  .animate-progress-bar { width: 0%; animation: fillProgress 3s linear forwards; }
  
  @keyframes springIn { 
    0% { opacity: 0; transform: scale(0.8) translateY(30px); } 
    100% { opacity: 1; transform: scale(1) translateY(0); } 
  }
  
  @keyframes fillProgress { 
    0% { width: 0%; } 
    100% { width: 100%; } 
  }
</style>

